#!/bin/bash
YesNoSel () {
	local choice
	while true; do
		read -rp "$1 [yes/no]: " choice
		case "$choice" in
			[Yy]|[Yy][Ee][Ss] ) CC=1; break;;
			[Nn]|[Nn][Oo] ) CC=0; break;;
			* ) echo "Rispondi 'yes' (y) o 'no' (n).";;
		esac
	done
}
MenuSel () {
	local -n var_name="$1"; local question="$2" user_choice; shift 2; local options=("$@")
	while true; do
		echo -e "\n=== $question ==="
		for i in "${!options[@]}"; do echo "$((i+1))) ${options[$i]}"; done
		read -rp "Scelta: " user_choice
		if [[ "$user_choice" =~ ^[0-9]+$ ]] && [ "$user_choice" -le "${#options[@]}" ] && [ "$user_choice" -gt 0 ]; then
			var_name="${options[$((user_choice-1))]}"; echo "Selezionato: $var_name"; break
		else echo "Scelta non valida, riprova."; fi
	done
}
TextPromptSel () {
	local -n var_name="$1"; local prompt_msg="$2" input_val
	while true; do
		read -rp "$prompt_msg: " input_val
		YesNoSel "Confermi che << $input_val >> è corretto?"
		if [[ "$CC" -eq 1 ]]; then var_name="$input_val"; break; fi
		echo "Riproiamo..."
	done
}
UEFIsel () {
	if [[ -d "/sys/firmware/efi/" ]]; then
		mount | grep -q "/sys/firmware/efi/efivars" || mount -t efivarfs efivarfs /sys/firmware/efi/efivars
		UEFImode=1 && echo 'UEFI Mode detected'
	else UEFImode=0 && echo 'BIOS Mode detected'; fi
}
CPUsel () {
	if grep -q "GenuineIntel" /proc/cpuinfo; then echo 'Installing Intel microcode'; microcodepkg='intel-ucode'
	elif grep -q "AuthenticAMD" /proc/cpuinfo; then echo 'Installing AMD microcode'
		[[ "$OSsel" == "Void" ]] && microcodepkg='amd-ucode-firmware' || microcodepkg='amd-ucode'
	else echo 'No microcode needed or unknown CPU'; fi
}
GPUsel () {
	echo "Detecting video chipset..."
	local gpu_info=$(lspci | grep -Ei 'VGA|3D')
	case "$gpu_info" in
		*Intel*) echo "The default Mesa driver will be installed" ;;
		*NVIDIA*) YesNoSel 'Found Nvidia gpu, wanna proprietary driver? If you do not like it, Mesa is the default'
			if [ "$CC" -eq 1 ]; then echo 'Setting up NVIDIA Drivers' 
				if [[ "$OSsel" == "Void" ]]; then nvidiadrivers=(nvidia nvidia-libs-32bit)
				else YesNoSel 'Do you want the official NVIDIA OPEN-source kernel modules? (No = Classic Proprietary)'
					local open_driver="$CC"; local nv_main
					if [ "$open_driver" -eq 1 ]; then [[ "$KSel" == "linux" ]] && nv_main="nvidia-open" || nv_main="nvidia-open-dkms"
					else
						if [[ "$KSel" == "linux" ]]; then nv_main="nvidia"
						elif [[ "$KSel" == "linux-lts" ]]; then nv_main="nvidia-lts"
						else nv_main="nvidia-dkms"; fi
					fi
					nvidiadrivers=("$nv_main" nvidia-prime nvidia-settings nvidia-utils lib32-nvidia-utils opencl-nvidia lib32-opencl-nvidia libxnvctrl libvdpau)
				fi
			else echo 'Using default Mesa'; fi
			[ -f /sys/firmware/acpi/tables/DSDT ] && AcpiOS="$(strings /sys/firmware/acpi/tables/DSDT | grep -i 'windows ' | sort | tail -1)" ;;
		*AMD*|*Radeon*) if [[ "$OSsel" == "Void" ]]; then amddrivers=(xf86-video-amdgpu mesa-dri vulkan-loader mesa-vulkan-radeon libva-vdpau-driver)
			else amddrivers=(amdgpu mesa vulkan-radeon libva-mesa-driver mesa-vdpau); fi ;;
		*VMware*|*VirtualBox*|*Virtio*|*QXL*) VBTsel=1; echo "VM detected: The default Mesa driver will be installed" ;;
		*) echo "Generic GPU: Mesa will be installed" ;;
	esac
}
Pacman_Locked() {
	if [ -f /var/lib/pacman/db.lck ] || [ -f /mnt/var/lib/pacman/db.lck ]; then
		echo -e "!!!ERROR!!! Pacman is blocked. Removing lockfiles..."; rm -f /var/lib/pacman/db.lck /mnt/var/lib/pacman/db.lck
	else echo "No locked database"; fi
}
ArchRepoSetup () {
	local target_conf="$1"
	local cmd=()
	[ "$target_conf" = "/mnt/etc/pacman.conf" ] && cmd=( "$chroot" /mnt )

	local mirror_file="/etc/pacman.d/mirrorlist-arch"
	[ "$target_conf" = "/mnt/etc/pacman.conf" ] && mirror_file="/mnt/etc/pacman.d/mirrorlist-arch"

	# AUTOMAZIONE KEYRING: Inizializza forzatamente il portachiavi a ogni avvio per evitare blocchi di permessi
	if [ ${#cmd[@]} -eq 0 ]; then
		sudo pacman-key --init 2>/dev/null || true
		sudo pacman-key --populate artix 2>/dev/null || true
	else
		"${cmd[@]}" pacman-key --init 2>/dev/null || true
		"${cmd[@]}" pacman-key --populate artix archlinux 2>/dev/null || true
	fi

	# AUTOMAZIONE UNIVERSE: Rimuove la vecchia sezione se presente per evitare conflitti o doppioni
	sed -i '/\[universe\]/,/^[[:space:]]*$/d' "$target_conf" 2>/dev/null || true
	
	# Scrive la tua lista esatta e immutabile
	cat << 'EOF' >> "$target_conf"

[universe]
Server = https://universe.artixlinux.org/$arch
Server = https://mirror1.artixlinux.org/universe/$arch
Server = https://mirror.pascalpuffke.de/artix-universe/$arch
Server = https://artixlinux.qontinuum.space/artixlinux/universe/os/$arch
Server = https://mirror1.cl.netactuate.com/artix/universe/$arch
Server = https://ftp.crifo.org/artix-universe/$arch
EOF

	# AUTOMAZIONE ARCH REPO: Forza l'installazione del supporto mirror se il file manca sul disco
	if [ ! -f "$mirror_file" ]; then
		"${cmd[@]}" pacman -Sy --noconfirm artix-keyring artix-archlinux-support 2>/dev/null || true
	fi
	
	# Scrive la configurazione Arch solo se non è già presente nel testo
	if ! grep -q 'mirrorlist-arch' "$target_conf" 2>/dev/null; then
		cat << 'EOF' >> "$target_conf"

# Arch
[extra]
Include = /etc/pacman.d/mirrorlist-arch

[multilib]
Include = /etc/pacman.d/mirrorlist-arch
EOF
	fi

	# Sincronizzazione finale delle chiavi e dei database
	"${cmd[@]}" pacman-key --populate artix archlinux 2>/dev/null || true
	"${cmd[@]}" pacman -Sy 2>/dev/null || true
}
AnotherCheck () {
	[[ "$OSsel" == "Void" ]] && echo "Skipping check (Void uses XBPS)" && return 0
	local repos=(extra multilib); [[ "$OSsel" == "Artix" ]] && repos+=(system world galaxy)
	pacman -Sylq "${repos[@]}" | sort > pacman_db; printf '%s\n' "${miss[@]}" | sort -u > pkg_missed
	mapfile -t unlisted < <(comm -13 pacman_db pkg_missed); echo "Unlisted = ${unlisted[*]}"
}
KernelSel() { [[ "$OSsel" == "Void" ]] && MenuSel "KSel" "Select preferred Kernel" "linux" "linux-lts" || MenuSel "KSel" "Select preferred Kernel" "linux" "linux-lts" "linux-hardened" "linux-zen"; }
OperatingSystemSel()   { MenuSel "OSsel" "Select the distro to setup" "Arch" "Artix" "Void"; }
VoidInstMethod()       { MenuSel "VImethod" "Select installation type" "XBPS" "ROOTFS"; }
LibrarySel()           { MenuSel "LIBsel" "Select base library" "GLIBC" "MUSL"; }
LocalizationSel()      { MenuSel "LOCsel" "Select localization" "en_US.UTF-8" "en_GB.UTF-8" "it_IT.UTF-8"; }
LanguageSel()          { MenuSel "LANGsel" "Select preferred Language" "en_US.UTF-8" "en_GB.UTF-8" "it_IT.UTF-8"; }
PartIDSel()            { MenuSel "PIDsel" "Select partition identifier" "UUID" "PARTUUID" "LABEL"; }
FilesystemSel()        { MenuSel "FSsel" "Select filesystem for ROOT" "ext4" "btrfs"; }
BootloaderSel()        { MenuSel "BLsel" "Select Bootloader" "refind" "grub" "efistub"; }
HostnameSel()          { TextPromptSel "HNsel" "Enter preferred hostname"; }
UsernameSel()          { TextPromptSel "UNsel" "Enter preferred username"; }
VirtualBoxTest () { YesNoSel "If this is a Virtualbox installation for test, skip every choice?"; VBTsel="$CC"; [[ "$VBTsel" -eq 1 ]] && echo "OK, skip all checks." || echo "OK, let's proceed with questions."; }
ArchRepoSel () { YesNoSel "You want Arch repositories as well as Artix repositories?"; if [[ "$CC" -eq 1 ]]; then ARCHrepo=1 && echo "OK, adding Arch repositories!"; else ARCHrepo='' && echo "Proceeding without them..."; fi; }
TimezoneSel () {
	local -n var_name="$1"
	while true; do
		echo -e "\n=== Select Timezone ==="; echo "1) Europe/Rome"
		read -rp "Type '1' or write custom format (e.g. America/New_York) ['q' to quit]: " input_val
		case "$input_val" in
			1) var_name="Europe/Rome" ; break ;;
			q|quit) var_name="" ; break ;;
			"") echo "Input cannot be empty." ;;
			*) YesNoSel "Confirm timezone: $input_val ?"
				if [[ "$CC" -eq 1 ]]; then var_name="$input_val"; break; fi ;;
		esac
	done
	echo "Selected Timezone: $var_name"
}
