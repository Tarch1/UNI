#!/bin/bash

YesNoSel () {
	local choice
	while true; do
		read -rp "$1 [yes/no]: " choice
		case "$choice" in
			[Yy]|[Yy][Ee][Ss] ) CC=1; break;;
			[Nn]|[Nn][Oo] ) CC=0; break;;
			* ) echo "Rispondi 'yes' (y) o 'no' (n).";;
		esac
	done
}

MenuSel () {
	local var_name="$1" question="$2" user_choice i
	shift 2
	local options=("@")
	while true; do
		echo -e "\n=== $question ==="
		for i in "${!options[@]}"; do echo "$((i+1))) ${options[$i]}"; done
		read -rp "Scelta: " user_choice
		if [[ "$user_choice" =~ ^[0-9]+$ ]] && [ "$user_choice" -le "${#options[@]}" ] && [ "$user_choice" -gt 0 ]; then
			local selected_val="${options[$((user_choice-1))]}"
			eval "$var_name=\"$selected_val\""
			echo "Selezionato: $selected_val"
			break
		else
			echo "Scelta non valida, riprova."
		fi
	done
}

TextPromptSel () {
	local var_name="$1" prompt_msg="$2" input_val
	while true; do
		read -rp "$prompt_msg: " input_val
		if [[ -z "$input_val" ]]; then echo "L'input non può essere vuoto."; continue; fi
		YesNoSel "Confermi che << $input_val >> è corretto?"
		[[ "$CC" -eq 1 ]] && eval "$var_name=\"$input_val\"" && break
		echo "Riproviamo..."
	done
}

UEFIsel () {
	if [[ -d "/sys/firmware/efi/" ]]; then
		mount | grep -q "/sys/firmware/efi/efivars" || mount -t efivarfs efivarfs /sys/firmware/efi/efivars
		UEFImode=1 && echo 'UEFI Mode detected'
	else 
		UEFImode=0 && echo 'BIOS Mode detected'
	fi
}

CPUsel () {
	local cpu_vendor=$(lscpu | grep -Eo "GenuineIntel|AuthenticAMD" | head -n1)
	case "$cpu_vendor" in
		GenuineIntel) echo 'Installing Intel microcode'; microcodepkg='intel-ucode' ;;
		AuthenticAMD) echo 'Installing AMD microcode'; microcodepkg='amd-ucode' ;;
		*) echo 'No microcode needed or unknown CPU' ;;
	esac	
}

GPUsel () {
	echo "Detecting video chipset..."
	local gpu_info=$(lspci | grep -Ei 'VGA|3D')
	case "$gpu_info" in
		*Intel*) echo "The default Mesa driver will be installed" ;;
		*NVIDIA*) 
			YesNoSel 'Found Nvidia gpu, wanna proprietary driver? If you do not like it, Mesa is the default'
			if [ "$CC" -eq 1 ]; then
				echo 'Setting up Proprietary Drivers' 
				case "$KSel" in
					linux)     nvidiadrivers=(nvidia) ;;
					linux-lts) nvidiadrivers=(nvidia-lts) ;;
					*)         nvidiadrivers=(nvidia-dkms) ;;
				esac
				nvidiadrivers+=(nvidia-prime nvidia-settings nvidia-utils lib32-nvidia-utils opencl-nvidia lib32-opencl-nvidia libxnvctrl libvdpau)
			else
				echo 'Using default Mesa'
			fi
			[ -f /sys/firmware/acpi/tables/DSDT ] && AcpiOS="$(strings /sys/firmware/acpi/tables/DSDT | grep -i 'windows ' | sort | tail -1)"
			;;
		*AMD*|*Radeon*) amddrivers=(amdgpu mesa vulkan-radeon libva-mesa-driver mesa-vdpau) ;;
		*VMware*|*VirtualBox*|*Virtio*|*QXL*) VBTsel=1 && echo "VM detected: The default Mesa driver will be installed" ;;
		*) echo "Generic GPU: Mesa will be installed" ;;
	esac
}

Pacman_Locked() {
	if [ -f /var/lib/pacman/db.lck ] || [ -f /mnt/var/lib/pacman/db.lck ]; then
		echo -e "!!!ERROR!!! Pacman is blocked. Removing lockfiles..."
		rm -f /var/lib/pacman/db.lck /mnt/var/lib/pacman/db.lck
	else 
		echo "No locked database"
	fi
}

ArchRepoSetup () {
	local target_conf="$1" pm="${PKGmanager:-pacman}" ch="${chroot:-artix-chroot}"
	if ! grep -q 'universe' "$target_conf" 2>/dev/null; then 
		cat << 'EOF' >> "$target_conf"

[universe]
Server = https://artixlinux.org\$arch
Server = https://artixlinux.org\$arch
EOF
	fi
	if ! grep -q 'mirrorlist-arch' "$target_conf" 2>/dev/null; then 
		local cmd=("$pm" -Sy "${pkgskips[@]}" artix-archlinux-support)
		[ "$target_conf" = /mnt/etc/pacman.conf ] && "$ch" /mnt "${cmd[@]}" || "${cmd[@]}"
		cat << 'EOF' >> "$target_conf"

# Arch
[extra]
Include = /etc/pacman.d/mirrorlist-arch
[community]
Include = /etc/pacman.d/mirrorlist-arch
[multilib]
Include = /etc/pacman.d/mirrorlist-arch
EOF
		if [ "$target_conf" = /mnt/etc/pacman.conf ]; then
			"$ch" /mnt pacman-key --populate archlinux
			"$ch" /mnt "$pm" -Sy
		else
			pacman-key --populate archlinux && "$pm" -Sy
		fi
	fi
	[[ -s /etc/pacman.d/mirrorlist-arch ]] || pacman -Sy artix-archlinux-support --noconfirm 2>/dev/null || true
}

AnotherCheck () {
	pacman -Sylq system world galaxy extra community multilib | sort > pacman_db
	printf '%s\n' "${miss[@]}" | sort -u > pkg_missed
	mapfile -t unlisted < <(comm -13 pacman_db pkg_missed)
	echo "Unlisted = ${unlisted[*]}"
}

KernelSel()            { MenuSel "KSel" "Select preferred Kernel" "linux" "linux-lts" "linux-hardened" "linux-zen"; }
OperatingSystemSel()   { MenuSel "OSsel" "Select the distro to setup" "Arch" "Artix" "Void"; }
VoidInstMethod()       { MenuSel "VImethod" "Select installation type" "XBPS" "ROOTFS"; }
LibrarySel()           { MenuSel "LIBsel" "Select base library" "GLIBC" "MUSL"; }
LocalizationSel()      { MenuSel "LOCsel" "Select localization" "en_US.UTF-8" "en_GB.UTF-8" "it_IT.UTF-8"; }
LanguageSel()          { MenuSel "LANGsel" "Select preferred Language" "en_US.UTF-8" "en_GB.UTF-8" "it_IT.UTF-8"; }
PartIDSel()            { MenuSel "PIDsel" "Select partition identifier" "UUID" "PARTUUID" "LABEL"; }
FilesystemSel()        { MenuSel "FSsel" "Select filesystem for ROOT" "ext4" "btrfs"; }
BootloaderSel()        { MenuSel "BLsel" "Select Bootloader" "refind" "grub" "efistub"; }
HostnameSel()          { TextPromptSel "HNsel" "Enter preferred hostname"; }
UsernameSel()          { TextPromptSel "UNsel" "Enter preferred username"; }

VirtualBoxTest () {
	YesNoSel "If this is a Virtualbox installation for test, skip every choice?"
	VBTsel="$CC"
	[[ "$VBTsel" -eq 1 ]] && echo "OK, skip all checks." || echo "OK, let's proceed with questions."
}

ArchRepoSel () {
	YesNoSel "You want Arch repositories as well as Artix repositories?"
	if [[ "$CC" -eq 1 ]]; then ARCHrepo=1 && echo "OK, adding Arch repositories!"; else ARCHrepo='' && echo "Proceeding without them..."; fi
}

TimezoneSel () {
	local TZsel
	while true; do
		echo -e "\n=== Select Timezone ==="
		echo "1) Europe/Rome"
		read -rp "Type '1' or write custom format (e.g. America/New_York) ['q' to quit]: " TZsel
		case "$TZsel" in
			1) TZsel="Europe/Rome" ; break ;;
			q|quit) TZsel="" ; break ;;
			"") echo "Input cannot be empty." ;;
			*) 
				YesNoSel "Confirm timezone: $TZsel ?"
				[[ "$CC" -eq 1 ]] && break
				;;
		esac
	done
	echo "Selected Timezone: $TZsel"
}
